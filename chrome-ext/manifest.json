{
  "manifest_version": 3,
  "name": "Hedgehog Vision",
  "version": "0.3.0",
  "description": "Auto-injects the vision-based auto-clicker into Ёжики and captures fresh VK launch URLs.",
  "permissions": ["debugger", "storage"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Open Ёжики (uses last captured VK URL)"
  },
  "content_scripts": [
    {
      "matches": ["https://valley.redspell.ru/*"],
      "js": ["iframe-script.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["https://valley.redspell.ru/*"],
      "js": ["iframe-isolated.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "https://vk.com/ezhiky_game*",
        "https://vk.com/app*",
        "https://m.vk.com/ezhiky_game*",
        "https://m.vk.com/app*"
      ],
      "js": ["vk-launcher.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://valley.redspell.ru/*", "https://vk.com/*", "https://m.vk.com/*"]
}
